# Copy to .env and fill in values
# Used for local development (cargo run)

# Synology NAS connection
SYNOLOGY_HOST=192.168.1.100
SYNOLOGY_PORT=5001
SYNOLOGY_USER=mcp_user
SYNOLOGY_PASSWORD=your_password_here
SYNOLOGY_HTTPS=true

# MCP server
MCP_AUTH_TOKEN=your_secret_token_here
MCP_PORT=3000

# Logging
RUST_LOG=synology_mcp=debug
